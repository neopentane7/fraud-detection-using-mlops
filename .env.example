# Copy to `.env` and fill in real values. `.env` is git-ignored.
# Loaded automatically via python-dotenv in pipeline scripts.

# --- Kaggle API credentials (https://www.kaggle.com/settings -> Create New Token) ---
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# --- MLflow tracking server ---
# Local docker-compose server. Inside the API container this becomes http://mlflow:5000.
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Model serving configuration ---
MODEL_NAME=fraud-detector
MODEL_STAGE=Production

# --- Prediction audit log location (JSONL) ---
PREDICTION_LOG_PATH=predictions.jsonl
